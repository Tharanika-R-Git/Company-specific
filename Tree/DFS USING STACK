import java.util.*;
public class Main{
    public void preorder(TreeNode root){
        if(root==null)return;
        Stack<TreeNode>stk = new Stack<>;
        stk.push(root);
        while(!stk.isEmpty()){
            TreeNode node = stk.pop();
            System.out.print(node.val);
            if(node.right!=null){
                stk.push(node.right);
            }
            if(node.left!=null){
                stk.push(node.left)
            }
        }
    }
}
